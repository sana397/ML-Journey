   "source": [
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "x = np.linspace(-5,5,100)\n",
    "y= x **2\n",
    "dy = 2 *x\n",
    "plt.plot(x,y,label='f(x)=x^2')\n",
    "plt.plot(x,dy,label=\"f'(x) = 2x\")\n",
    "plt.legend()\n",
    "plt.title(\"Function and its derivative\")\n",
    "plt.grid(True)\n",
    "plt.show()"
   ]
  }
 ],
